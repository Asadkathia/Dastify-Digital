{
  "name": "dastify-digital",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "predev": "node -e \"const { execSync } = require('node:child_process'); const uri = process.env.DATABASE_URI || 'file:'; const isSqlite = uri.startsWith('file:'); const isPg = /^postgres(ql)?:\\/\\//i.test(uri); if (isSqlite || isPg) { execSync('npm run db:migrate', { stdio: 'inherit' }); execSync('npm run db:verify', { stdio: 'inherit' }); } else { console.log('[predev] skipping db:migrate/db:verify for unsupported DATABASE_URI scheme'); }\"",
    "dev": "next dev",
    "dev:node22": "npm run db:migrate && npm run db:verify && npx -y node@22 ./node_modules/next/dist/bin/next dev",
    "prebuild": "npm run db:migrate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "payload": "payload",
    "payload:node22": "npx -y node@22 ./node_modules/.bin/payload",
    "payload:types": "npm run payload:node22 -- generate:types",
    "payload:importmap": "npm run payload:node22 -- generate:importmap",
    "seed:homepage": "node --import tsx ./scripts/seed-homepage.ts",
    "seed:cms-baseline": "node --import tsx ./scripts/seed-cms-baseline.ts",
    "seed:homepage:node22": "npx -y node@22 --import tsx ./scripts/seed-homepage.ts",
    "pages:reset": "node --import tsx ./scripts/reset-converted-content.ts",
    "db:migrate": "node --import tsx ./scripts/db-migrate.ts",
    "db:verify": "node --import tsx ./scripts/db-verify-schema.ts",
    "migrations:check": "node --import tsx ./scripts/check-migration-parity.ts",
    "gate:local": "node --import tsx ./scripts/verify-rollout-gates.ts local",
    "gate:runtime": "node --import tsx ./scripts/verify-rollout-gates.ts runtime",
    "gate:full": "node --import tsx ./scripts/verify-rollout-gates.ts full",
    "health:admin": "npx -y node@22 --import tsx ./scripts/admin-health.ts",
    "remote-db:create": "bash ./scripts/create-remote-db.sh",
    "db:backup": "node --import tsx ./scripts/db-backup.ts",
    "db:restore": "node --import tsx ./scripts/db-restore.ts",
    "db:migrate:safe": "npm run db:backup -- --label pre-migrate && npm run db:migrate",
    "db:fix-homepage-schema": "node --import tsx ./scripts/fix-homepage-schema.ts",
    "seed:homepage:safe": "npm run db:backup -- --label pre-seed && npm run seed:homepage",
    "seed:cms-baseline:safe": "npm run db:backup -- --label pre-seed-cms-baseline && npm run seed:cms-baseline",
    "sync:homepage-media:safe": "npm run db:backup -- --label pre-sync-media && npm run sync:homepage-media",
    "sync:media:to:neon": "node ./scripts/sync-media-to-neon.mjs",
    "sync:pages:to:neon": "node --import tsx ./scripts/sync-pages-to-neon.ts",
    "smoke": "npx -y node@22 --import tsx ./scripts/smoke.ts",
    "deploy:vercel": "bash ./scripts/deploy-vercel.sh",
    "sync:homepage-media": "node --import tsx ./scripts/sync-homepage-media.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@payloadcms/db-postgres": "^3.81.0",
    "@payloadcms/db-sqlite": "^3.81.0",
    "@payloadcms/next": "^3.81.0",
    "@payloadcms/plugin-cloud-storage": "^3.81.0",
    "@payloadcms/plugin-form-builder": "^3.81.0",
    "@payloadcms/plugin-nested-docs": "^3.81.0",
    "@payloadcms/plugin-redirects": "^3.81.0",
    "@payloadcms/plugin-search": "^3.81.0",
    "@payloadcms/plugin-seo": "^3.81.0",
    "@payloadcms/richtext-lexical": "^3.81.0",
    "@payloadcms/storage-vercel-blob": "^3.81.0",
    "next": "16.2.2",
    "payload": "^3.81.0",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zundo": "^2.3.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "typescript": "^5",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "@libsql/client": "^0.17.2",
    "@libsql/hrana-client": "^0.7.0"
  }
}
